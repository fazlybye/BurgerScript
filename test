-- ── MISC TAB ────────────────────────────────────────────────────────────────
local Misc = Window:AddTab("Misc")

Misc:New("Title")({ Title = "Luas" })

local function listLuas()
    local files = listfiles("Aqua.Hook/Luas")
    local names = {}
    for _, path in ipairs(files) do
        if path:sub(-4) == ".lua" then
            local name = path:match("[/\\]([^/\\]+)%.lua$") or path
            table.insert(names, name)
        end
    end
    return names
end

for _, folder in ipairs({ "Aqua.Hook", "Aqua.Hook/Luas" }) do
    if not isfolder(folder) then makefolder(folder) end
end

local LuaDropdown
LuaDropdown = Misc:New("Dropdown")({
    Title   = "Select Lua",
    Options = listLuas(),
    Callback = function(v) end,
})

Misc:New("Button")({
    Title    = "Refresh",
    Callback = function()
        LuaDropdown:SetOptions(listLuas())
    end,
})

Misc:New("Button")({
    Title    = "Load Selected",
    Callback = function()
        if LuaDropdown.Value and LuaDropdown.Value ~= "" then
            local path = "Aqua.Hook/Luas/" .. LuaDropdown.Value .. ".lua"
            local fn, err = loadfile(path)
            if fn then
                task.spawn(fn)
            else
                Window:Notify({ Title = "Error", Description = tostring(err), Duration = 5, Type = "Error" })
            end
        end
    end,
})

Misc:New("Button")({
    Title    = "Load All",
    Callback = function()
        for _, name in ipairs(listLuas()) do
            local fn, err = loadfile("Aqua.Hook/Luas/" .. name .. ".lua")
            if fn then
                task.spawn(fn)
            else
                Window:Notify({ Title = "Error", Description = tostring(err), Duration = 4, Type = "Error" })
            end
        end
    end,
})

